# ============================================================================
# Max configuration — copy to ~/.max/.env and edit.
# Systemd user service loads this file via EnvironmentFile.
# ============================================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (send /myid to @userinfobot to get it)
AUTHORIZED_USER_ID=123456789

# ----------------------------------------------------------------------------
# HTTP API (served to TUI + web UI + cog-trigger admin endpoint)
# ----------------------------------------------------------------------------
# API_PORT: Port the daemon listens on (default: 7777)
API_PORT=7777

# API_BIND: Bind address. Default is 127.0.0.1 (localhost only). Set to
# 0.0.0.0 to expose to your LAN (authentication required — see AUTH_*).
# API_BIND=0.0.0.0

# ----------------------------------------------------------------------------
# WebAuthn / Passkey / TOTP (required when API_BIND exposes the LAN)
# ----------------------------------------------------------------------------
# AUTH_RP_ID: Passkey Relying Party ID — the hostname clients use to reach the
# web UI. Must match AUTH_RP_ORIGIN's host. Default: "localhost".
# AUTH_RP_ID=max.local

# AUTH_RP_ORIGIN: Full origin (scheme + host + port) clients connect to.
# Default: http://localhost:${API_PORT}
# AUTH_RP_ORIGIN=http://max.local:7777

# AUTH_SESSION_TTL: Session lifetime in hours (default: 720 = 30 days)
# AUTH_SESSION_TTL=720

# ----------------------------------------------------------------------------
# Copilot model
# ----------------------------------------------------------------------------
# Default model — auto mode may override per message.
# COPILOT_MODEL=claude-sonnet-4.6

# ----------------------------------------------------------------------------
# Agent worker timeout
# ----------------------------------------------------------------------------
# Timeout for delegated agent tasks, in milliseconds (default: 600000 = 10 min).
# Increase for complex implementation work. Examples: 1800000 (30m), 3600000 (1h).
# WORKER_TIMEOUT=1800000

# ============================================================================
# Memory — COG
# ============================================================================
# COG (Cognitive Architecture) lives at ~/.max/cog/ and is self-configured.
# No env-var knobs: cadence, thresholds, and file budgets are module constants
# in src/cog/scheduler.ts. Persona and memory rules live in ~/.max/cog/SYSTEM.md
# (edit directly — it's user data, not source code).
#
# Scheduler runs inside the daemon:
#   - cog-reflect:      >20 h since last + >=10 new conversation_log rows
#   - cog-housekeeping: weekly
#   - cog-foresight:    daily (06:00-11:00) when briefing-bridge.md exists
#
# On-demand triggers:
#   max reflect      # POSTs /cog/trigger { skill: "reflect",      force: true }
#   max housekeeping # POSTs /cog/trigger { skill: "housekeeping", force: true }
#   max evolve       # POSTs /cog/trigger { skill: "evolve",       force: true }
# systemd timers for these are installed via `max service install-<name>`.
