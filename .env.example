# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (send /myid to @userinfobot to get it)
AUTHORIZED_USER_ID=123456789

# Local API port for TUI (default: 7777)
API_PORT=7777

# Copilot model (default: claude-sonnet-4.5)
COPILOT_MODEL=claude-sonnet-4.5

# Agent worker timeout in milliseconds (default: 600000 = 10 minutes)
# Increase for complex implementation tasks that need more time
# Recommended: 1800000 (30 minutes) or 3600000 (60 minutes)
# WORKER_TIMEOUT=1800000

# ============================================================================
# MEMORY SYSTEM CONFIGURATION (Runs nightly via systemd timers)
# ============================================================================

# ----------------------------------------------------------------------------
# Reflection (5 AM daily) — Mine conversations, detect patterns, update memory
# ----------------------------------------------------------------------------
# REFLECT_ENABLED: Enable/disable reflection pipeline (default: true)
REFLECT_ENABLED=true

# REFLECT_NOTIFY_TELEGRAM: Send Telegram summary after each run (default: true)
REFLECT_NOTIFY_TELEGRAM=true

# REFLECT_NOTIFY_ON_ERROR_ONLY: Only notify on errors, skip success summaries (default: false)
REFLECT_NOTIFY_ON_ERROR_ONLY=false

# REFLECT_HOURS: Hours of conversation history to mine each run (default: 24)
REFLECT_HOURS=24

# REFLECT_PATTERN_THRESHOLD: Minimum observations needed to detect a pattern (default: 3)
REFLECT_PATTERN_THRESHOLD=3

# ----------------------------------------------------------------------------
# Housekeeping (3 AM daily) — Prune, archive, audit links, rebuild index
# ----------------------------------------------------------------------------
# HOUSEKEEPING_ENABLED: Enable/disable housekeeping pipeline (default: true)
HOUSEKEEPING_ENABLED=true

# HOUSEKEEPING_NOTIFY_TELEGRAM: Send Telegram summary after each run (default: true)
HOUSEKEEPING_NOTIFY_TELEGRAM=true

# HOUSEKEEPING_NOTIFY_ON_ERROR_ONLY: Only notify on errors (default: false)
HOUSEKEEPING_NOTIFY_ON_ERROR_ONLY=false

# ----------------------------------------------------------------------------
# Evolution (4 AM daily) — Audit architecture, evaluate rules, propose changes
# ----------------------------------------------------------------------------
# EVOLVE_ENABLED: Enable/disable evolution pipeline (default: true)
EVOLVE_ENABLED=true

# EVOLVE_NOTIFY_TELEGRAM: Send Telegram summary after each run (default: true)
EVOLVE_NOTIFY_TELEGRAM=true

# EVOLVE_NOTIFY_ON_ERROR_ONLY: Only notify on errors (default: false)
EVOLVE_NOTIFY_ON_ERROR_ONLY=false

# EVOLVE_HOT_MEMORY_CAP: Maximum lines for hot-memory.md before pruning (default: 50)
EVOLVE_HOT_MEMORY_CAP=50

# EVOLVE_OBSERVATION_ARCHIVE_THRESHOLD: Max observations before archival (default: 500)
EVOLVE_OBSERVATION_ARCHIVE_THRESHOLD=500
