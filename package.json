{
  "name": "heymax",
  "version": "1.5.0",
  "description": "Max — a personal AI assistant for developers, built on the GitHub Copilot SDK",
  "bin": {
    "max": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.md",
    "web/dist/**",
    "scripts/*.template",
    "agents/",
    "skills/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').mkdirSync('dist/cog',{recursive:true});require('fs').copyFileSync('src/cog/default-system.md','dist/cog/default-system.md')\" && npm run web:build",
    "build:daemon": "tsc && node -e \"require('fs').mkdirSync('dist/cog',{recursive:true});require('fs').copyFileSync('src/cog/default-system.md','dist/cog/default-system.md')\"",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "daemon": "tsx src/daemon.ts",
    "tui": "tsx src/tui/index.ts",
    "dev": "tsx --watch src/daemon.ts",
    "prepublishOnly": "npm run build",
    "migrate-l0": "tsx scripts/migrate-l0-headers.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "copilot",
    "telegram",
    "orchestrator",
    "ai",
    "cli"
  ],
  "author": "Burke Holland",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/burkeholland/max.git"
  },
  "homepage": "https://github.com/burkeholland/max#readme",
  "bugs": {
    "url": "https://github.com/burkeholland/max/issues"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "@simplewebauthn/server": "^13.3.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "grammy": "^1.40.0",
    "otpauth": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
